{
  "name": "@markhhh/dxf-writer",
  "version": "4.2.2",
  "description": "Dead simple 2D DXF writer",
  "main": "index.js",
  "types": "./index.d.ts",
  "directories": {
    "example": "examples"
  },
  "scripts": {
    "test": "jasmine spec/*.spec.js",
    "bundle": "browserify -r ./src/BrowserFriendlyDrawing.js:Drawing -r ./src/StringWritableStream.js:StringWritableStream > ./examples/browser/dxf_bundle.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hendriksen-mark/js-dxf.git"
  },
  "keywords": [
    "DXF",
    "CAD",
    "AutoCAD"
  ],
  "author": "Ognjen Petrovic",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/hendriksen-mark/js-dxf/issues"
  },
  "homepage": "https://github.com/hendriksen-mark/js-dxf#readme",
  "devDependencies": {
    "husky": "^1.1.0",
    "jasmine": "^3.2.0",
    "browserify": "^16.2.3",
    "minimist": ">=1.2.3"
  },
  "husky": {
    "hooks": {
      "pre-push": "npm test"
    }
  }
}
